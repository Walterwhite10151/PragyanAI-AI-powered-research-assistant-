# ============================================================
#  AI Research Agent — Backend Environment Configuration
# ============================================================

# ── LLM Provider (choose one or both) ────────────────────────
# Groq (fast, free tier available): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (Google): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Default provider: "groq" or "gemini"
DEFAULT_LLM_PROVIDER=groq

# ── Exa Web Search ────────────────────────────────────────────
# Get your key: https://exa.ai
EXA_API_KEY=your_exa_api_key_here
EXA_MAX_RESULTS=5
EXA_USE_HIGHLIGHTS=true

# ── Embeddings (local, no API key needed) ────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=research_docs

# ── Storage ──────────────────────────────────────────────────
CONVERSATION_HISTORY_PATH=./data/conversation_history
UPLOADS_PATH=./data/uploads
LOGS_PATH=./logs

# ── YouTube ──────────────────────────────────────────────────
MAX_YOUTUBE_RESULTS=5

# ── Agent ────────────────────────────────────────────────────
SUMMARY_MAX_TOKENS=2048
RESEARCH_TEMPERATURE=0.3

# ── FastAPI Server ────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
